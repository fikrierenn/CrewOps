@page "/project/{ProjectId:guid}/leads"
@using CrewOps.Domain.Entities
@using CrewOps.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@inject IDbContextFactory<CrewOpsDbContext> DbFactory
@rendermode InteractiveServer

<div class="leads-header">
    <h1>Potansiyel Musteriler</h1>
    @if (_leads.Any())
    {
        <div class="leads-filter">
            <button class="filter-btn @(_filter == "all" ? "active" : "")" @onclick="FilterAll">Tümü (@_leads.Count)</button>
            <button class="filter-btn @(_filter == "yok" ? "active" : "")" @onclick="FilterNoSite">Sitesiz (@_leads.Count(l => l.WebsiteStatus == "yok"))</button>
            <button class="filter-btn @(_filter == "kötü" ? "active" : "")" @onclick="FilterBadSite">Kötü Site (@_leads.Count(l => l.WebsiteStatus == "kötü"))</button>
            <button class="filter-btn @(_filter == "demo" ? "active" : "")" @onclick="FilterDemo">Demo Hazır (@_leads.Count(l => l.DemoSiteUrl is not null))</button>
        </div>
    }
</div>

@if (_leads.Any())
{
    <div class="summary-cards">
        <div class="card">
            <div class="card-value">@_leads.Count</div>
            <div class="card-label">Toplam Lead</div>
        </div>
        <div class="card card-success">
            <div class="card-value">@_leads.Count(l => l.WebsiteStatus == "yok")</div>
            <div class="card-label">Sitesiz (Hedef)</div>
        </div>
        <div class="card card-warning">
            <div class="card-value">@_leads.Count(l => l.WebsiteStatus == "kötü")</div>
            <div class="card-label">Kötü Site (SEO Sat)</div>
        </div>
        <div class="card card-info">
            <div class="card-value">@_leads.Count(l => l.DemoSiteUrl is not null)</div>
            <div class="card-label">Demo Hazır</div>
        </div>
        @if (_leads.Any(l => l.SeoScore.HasValue))
        {
            <div class="card card-accent">
                <div class="card-value">@(_leads.Where(l => l.SeoScore.HasValue).Average(l => l.SeoScore!.Value).ToString("F0"))</div>
                <div class="card-label">Ort. SEO Skoru</div>
            </div>
        }
    </div>

    <div class="leads-grid">
        @foreach (var lead in FilteredLeads)
        {
            <div class="lead-card @(_selectedLead?.Id == lead.Id ? "selected" : "")" @onclick="() => SelectLead(lead)">
                <div class="lead-card-header">
                    <div class="lead-name">@lead.Name</div>
                    <div class="lead-badges">
                        <span class="badge badge-@(lead.WebsiteStatus == "yok" ? "failed" : lead.WebsiteStatus == "kötü" ? "inreview" : "completed")">
                            @(lead.WebsiteStatus ?? "-")
                        </span>
                        @if (lead.SeoScore.HasValue)
                        {
                            <span class="seo-badge seo-@(lead.SeoScore >= 70 ? "good" : lead.SeoScore >= 40 ? "mid" : "bad")">
                                SEO @lead.SeoScore
                            </span>
                        }
                    </div>
                </div>
                <div class="lead-card-meta">
                    <span>📍 @(lead.District ?? lead.Address?.Split(',').LastOrDefault()?.Trim() ?? "-")</span>
                    <span>⭐ @(lead.GoogleRating?.ToString("F1") ?? "-") (@(lead.GoogleReviewCount ?? 0))</span>
                    @if (lead.Phone is not null)
                    {
                        <span>📞 @lead.Phone</span>
                    }
                </div>
                <div class="lead-card-actions">
                    @if (lead.DemoSiteUrl is not null)
                    {
                        <a href="@lead.DemoSiteUrl" target="_blank" class="action-btn action-demo">🌐 Demo</a>
                    }
                    @if (lead.Phone is not null)
                    {
                        <a href="https://wa.me/@(lead.Phone?.Replace("+","").Replace(" ",""))" target="_blank" class="action-btn action-whatsapp">💬 WhatsApp</a>
                    }
                </div>
            </div>
        }
    </div>

    @if (_selectedLead is not null)
    {
        <div class="lead-detail-panel">
            <div class="detail-header">
                <h2>@_selectedLead.Name</h2>
                <button class="close-btn" @onclick="() => _selectedLead = null">✕</button>
            </div>

            <div class="detail-section">
                <h3>Bilgiler</h3>
                <div class="detail-grid">
                    <div class="detail-item"><span class="detail-label">Adres</span><span>@(_selectedLead.Address ?? "-")</span></div>
                    <div class="detail-item"><span class="detail-label">Telefon</span><span>@(_selectedLead.Phone ?? "-")</span></div>
                    <div class="detail-item"><span class="detail-label">Puan</span><span>⭐ @(_selectedLead.GoogleRating?.ToString("F1") ?? "-")</span></div>
                    <div class="detail-item"><span class="detail-label">Yorum</span><span>@(_selectedLead.GoogleReviewCount ?? 0)</span></div>
                    <div class="detail-item"><span class="detail-label">Web Sitesi</span><span>@(_selectedLead.WebsiteUrl ?? "Yok")</span></div>
                    <div class="detail-item"><span class="detail-label">Durum</span><span class="badge badge-@_selectedLead.Status.ToLower()">@_selectedLead.Status</span></div>
                </div>
            </div>

            @if (_selectedLead.SeoScore.HasValue)
            {
                <div class="detail-section">
                    <h3>SEO Analizi</h3>
                    <div class="seo-score-bar">
                        <div class="seo-score-fill seo-@(_selectedLead.SeoScore >= 70 ? "good" : _selectedLead.SeoScore >= 40 ? "mid" : "bad")"
                             style="width: @(_selectedLead.SeoScore)%">
                        </div>
                        <span class="seo-score-text">@_selectedLead.SeoScore/100</span>
                    </div>
                    @if (_selectedLead.SeoReport is not null)
                    {
                        @try
                        {
                            var report = JsonSerializer.Deserialize<SeoReportView>(_selectedLead.SeoReport, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                            if (report is not null)
                            {
                                <div class="seo-details">
                                    <div class="seo-check @(report.HasTitle ? "pass" : "fail")">@(report.HasTitle ? "✅" : "❌") Title tag</div>
                                    <div class="seo-check @(report.HasMetaDescription ? "pass" : "fail")">@(report.HasMetaDescription ? "✅" : "❌") Meta description</div>
                                    <div class="seo-check @(report.HasViewport ? "pass" : "fail")">@(report.HasViewport ? "✅" : "❌") Mobile uyumlu</div>
                                    <div class="seo-check @(report.HasSsl ? "pass" : "fail")">@(report.HasSsl ? "✅" : "❌") SSL (HTTPS)</div>
                                    <div class="seo-check @(report.HasOgTags ? "pass" : "fail")">@(report.HasOgTags ? "✅" : "❌") Open Graph</div>
                                    <div class="seo-check @(report.HasCanonical ? "pass" : "fail")">@(report.HasCanonical ? "✅" : "❌") Canonical URL</div>
                                    <div class="seo-check @(report.H1Count == 1 ? "pass" : "fail")">@(report.H1Count == 1 ? "✅" : "❌") H1 tag (@report.H1Count)</div>
                                    <div class="seo-meta">⏱️ Yanıt: @(report.ResponseTimeMs)ms | 📄 @(report.HtmlSizeKb)KB | 🔗 @(report.LinkCount) link</div>
                                </div>

                                @if (report.Issues?.Count > 0)
                                {
                                    <div class="seo-issues">
                                        <h4>Sorunlar</h4>
                                        @foreach (var issue in report.Issues)
                                        {
                                            <div class="seo-issue">@issue</div>
                                        }
                                    </div>
                                }
                            }
                        }
                        catch { }
                    }
                </div>
            }

            @if (_selectedLead.Notes is not null)
            {
                <div class="detail-section">
                    <h3>Pazarlama Mesaji</h3>
                    <div class="marketing-msg">@_selectedLead.Notes</div>
                </div>
            }

            @if (_selectedLead.DemoSiteUrl is not null)
            {
                <div class="detail-section">
                    <h3>Demo Site</h3>
                    <iframe src="@_selectedLead.DemoSiteUrl" class="demo-preview-frame"></iframe>
                </div>
            }
        </div>
    }
}
else
{
    <div class="empty-state">
        <p>Henuz lead bulunmuyor. PM ile sohbet baslatin ve arastirma yaptirin.</p>
    </div>
}

<style>
.leads-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 12px; }
.leads-header h1 { font-size: 20px; }
.leads-filter { display: flex; gap: 6px; }
.filter-btn { padding: 6px 14px; border: 1px solid var(--border); border-radius: 8px; background: transparent; color: var(--text-secondary); font-size: 12px; cursor: pointer; transition: all .2s; }
.filter-btn:hover, .filter-btn.active { border-color: var(--accent); color: var(--accent-light); background: var(--accent-bg); }

.summary-cards { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
.summary-cards .card { flex: 1; min-width: 120px; padding: 16px; border-radius: 12px; background: var(--surface); border: 1px solid var(--border); text-align: center; }
.card-value { font-size: 28px; font-weight: 800; color: var(--text); }
.card-label { font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }
.card-success .card-value { color: var(--success); }
.card-warning .card-value { color: var(--warning); }
.card-info .card-value { color: var(--info); }
.card-accent .card-value { color: var(--accent-light); }

.leads-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 12px; }
.lead-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 16px; cursor: pointer; transition: all .2s; }
.lead-card:hover { border-color: var(--border-hover); transform: translateY(-2px); }
.lead-card.selected { border-color: var(--accent); box-shadow: 0 0 0 2px var(--accent-glow); }
.lead-card-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; margin-bottom: 8px; }
.lead-name { font-weight: 600; font-size: 14px; }
.lead-badges { display: flex; gap: 4px; flex-shrink: 0; }
.lead-card-meta { display: flex; flex-wrap: wrap; gap: 12px; font-size: 12px; color: var(--text-muted); margin-bottom: 10px; }
.lead-card-actions { display: flex; gap: 6px; }
.action-btn { padding: 4px 10px; border-radius: 6px; font-size: 11px; text-decoration: none; transition: all .2s; }
.action-demo { background: var(--accent-bg); color: var(--accent-light); border: 1px solid rgba(124,108,240,.2); }
.action-demo:hover { background: rgba(124,108,240,.15); }
.action-whatsapp { background: rgba(37,211,102,.1); color: #25d366; border: 1px solid rgba(37,211,102,.2); }
.action-whatsapp:hover { background: rgba(37,211,102,.15); }

.seo-badge { padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 600; }
.seo-good { background: rgba(52,211,153,.15); color: var(--success); }
.seo-mid { background: rgba(251,191,36,.15); color: var(--warning); }
.seo-bad { background: rgba(248,113,113,.15); color: var(--danger); }

/* Detail Panel */
.lead-detail-panel { position: fixed; right: 0; top: 0; width: 420px; height: 100vh; background: var(--surface); border-left: 1px solid var(--border); padding: 24px; overflow-y: auto; z-index: 200; animation: slideIn .3s ease; box-shadow: -8px 0 32px rgba(0,0,0,.5); }
@@keyframes slideIn { from { transform: translateX(100%); } to { transform: translateX(0); } }
.detail-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; }
.detail-header h2 { font-size: 16px; font-weight: 700; }
.close-btn { background: none; border: none; color: var(--text-muted); font-size: 18px; cursor: pointer; padding: 4px 8px; border-radius: 6px; }
.close-btn:hover { background: var(--surface-2); color: var(--text); }
.detail-section { margin-bottom: 20px; }
.detail-section h3 { font-size: 13px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
.detail-grid { display: grid; gap: 8px; }
.detail-item { display: flex; justify-content: space-between; font-size: 13px; padding: 6px 0; border-bottom: 1px solid var(--border); }
.detail-label { color: var(--text-muted); }

.seo-score-bar { position: relative; height: 24px; background: var(--surface-2); border-radius: 12px; overflow: hidden; margin-bottom: 12px; }
.seo-score-fill { height: 100%; border-radius: 12px; transition: width .5s ease; }
.seo-score-fill.seo-good { background: linear-gradient(90deg, var(--success), #6ee7b7); }
.seo-score-fill.seo-mid { background: linear-gradient(90deg, var(--warning), #fcd34d); }
.seo-score-fill.seo-bad { background: linear-gradient(90deg, var(--danger), #fca5a5); }
.seo-score-text { position: absolute; right: 8px; top: 3px; font-size: 12px; font-weight: 700; }
.seo-details { display: grid; gap: 4px; }
.seo-check { font-size: 13px; padding: 4px 0; }
.seo-meta { font-size: 11px; color: var(--text-muted); margin-top: 8px; padding: 8px; background: var(--surface-2); border-radius: 6px; }
.seo-issues { margin-top: 12px; }
.seo-issues h4 { font-size: 12px; color: var(--warning); margin-bottom: 6px; }
.seo-issue { font-size: 12px; padding: 4px 0; color: var(--text-secondary); }

.marketing-msg { background: var(--surface-2); border-radius: 8px; padding: 12px; font-size: 13px; line-height: 1.7; white-space: pre-wrap; }
.demo-preview-frame { width: 100%; height: 300px; border: 1px solid var(--border); border-radius: 8px; }
</style>

@code {
    [Parameter] public Guid ProjectId { get; set; }
    private List<Lead> _leads = [];
    private Lead? _selectedLead;
    private string _filter = "all";

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _leads = await db.Leads
            .Where(l => l.ProjectId == ProjectId)
            .OrderByDescending(l => l.GoogleRating)
            .ThenByDescending(l => l.GoogleReviewCount)
            .ToListAsync();
    }

    private IEnumerable<Lead> FilteredLeads => _filter switch
    {
        "yok" => _leads.Where(l => l.WebsiteStatus == "yok"),
        "kötü" => _leads.Where(l => l.WebsiteStatus == "kötü"),
        "demo" => _leads.Where(l => l.DemoSiteUrl is not null),
        _ => _leads
    };

    private void FilterAll() => SetFilter("all");
    private void FilterNoSite() => SetFilter("yok");
    private void FilterBadSite() => SetFilter("kötü");
    private void FilterDemo() => SetFilter("demo");
    private void SetFilter(string filter) { _filter = filter; _selectedLead = null; }
    private void SelectLead(Lead lead) => _selectedLead = _selectedLead?.Id == lead.Id ? null : lead;

    private sealed class SeoReportView
    {
        public int Score { get; set; }
        public int ResponseTimeMs { get; set; }
        public int HtmlSizeKb { get; set; }
        public bool HasTitle { get; set; }
        public bool HasMetaDescription { get; set; }
        public bool HasViewport { get; set; }
        public bool HasOgTags { get; set; }
        public bool HasCanonical { get; set; }
        public bool HasFavicon { get; set; }
        public bool HasSsl { get; set; }
        public int H1Count { get; set; }
        public int ImgCount { get; set; }
        public int ImgWithoutAlt { get; set; }
        public int LinkCount { get; set; }
        public List<string>? Issues { get; set; }
    }
}
